# Server Port
PORT=5000

# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxxx.mongodb.net/?retryWrites=true&w=majority

# Database Name
DB_NAME=medicare_connect

# Stripe Secret Key
STRIPE_SECRET_KEY=your_stripe_secret_key

# Client URL
CLIENT_URL=http://localhost:3000
